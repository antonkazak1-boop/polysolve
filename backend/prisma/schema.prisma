// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Market {
  id              String   @id @default(uuid())
  conditionId     String   @unique
  question        String
  description     String?
  category        String
  endDate         DateTime
  resolutionSource String?
  liquidity       Float    @default(0)
  volume          Float    @default(0)
  status          String   // OPEN, CLOSED, RESOLVED, DISPUTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prices          MarketPrice[]
  bets            Bet[]
  positions       PortfolioPosition[]
  alerts          Alert[]
  signals         StrategySignal[]

  @@index([status])
  @@index([category])
  @@index([endDate])
  @@map("markets")
}

model MarketPrice {
  id              String   @id @default(uuid())
  marketId        String
  outcome         String   // YES or NO
  price           Float    // 0-1
  timestamp       DateTime @default(now())
  liquidity       Float    @default(0)
  volume24h       Float?

  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, timestamp])
  @@index([timestamp])
  @@map("market_prices")
}

model Wallet {
  id              String   @id @default(uuid())
  address         String   @unique
  totalBets       Int      @default(0)
  totalVolume     Float    @default(0)
  totalPnl        Float    @default(0)
  averageRoi      Float    @default(0) // Главная метрика!
  winRate         Float    @default(0)
  lastActiveAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bets            Bet[]
  alerts          Alert[]

  @@index([averageRoi])
  @@index([totalPnl])
  @@map("wallets")
}

model Bet {
  id              String   @id @default(uuid())
  walletId        String
  marketId        String
  outcome         String   // YES or NO
  amount          Float
  price           Float    // Цена входа
  potentialRoi    Float    // (1 / price) - 1
  status          String   // ACTIVE, WON, LOST, CANCELLED
  pnl             Float?
  roi             Float?   // Фактический ROI после закрытия
  timestamp       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  position        PortfolioPosition?

  @@index([walletId])
  @@index([marketId])
  @@index([status])
  @@index([timestamp])
  @@map("bets")
}

model PortfolioPosition {
  id              String   @id @default(uuid())
  userId          String?  // Для мультипользовательской системы
  marketId        String
  betId           String?  @unique
  outcome         String   // YES or NO
  amount          Float
  entryPrice      Float
  currentPrice    Float?
  potentialPnl    Float?
  potentialRoi    Float?
  status          String   // ACTIVE, WON, LOST, CANCELLED
  entryTime       DateTime
  marketEndDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  bet             Bet?     @relation(fields: [betId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([entryTime])
  @@map("portfolio_positions")
}

model PortfolioSnapshot {
  id              String   @id @default(uuid())
  userId          String?
  totalBalance    Float
  totalInvested   Float
  totalPnl        Float
  totalRoi        Float
  activePositions Int
  wonPositions    Int
  lostPositions   Int
  timestamp       DateTime @default(now())

  @@index([userId, timestamp])
  @@index([timestamp])
  @@map("portfolio_snapshots")
}

model Alert {
  id              String   @id @default(uuid())
  type            String   // ARBITRAGE, ASYMMETRIC_RETURNS, NEW_BET, etc.
  strategy        String
  marketId        String?
  walletId        String?
  message         String
  confidence      Int      // 0-100
  data            String   @default("{}") // Дополнительные данные (JSON как строка для SQLite)
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  market          Market?  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  wallet          Wallet?  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([read])
  @@index([createdAt])
  @@map("alerts")
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  name                 String?
  role                 String    @default("user") // "admin" | "user"
  subscriptionEnd      DateTime?
  isActive             Boolean   @default(true)
  // Polymarket CLOB keys (AES-256-GCM encrypted)
  polyPrivateKeyEnc    String?
  polyApiKeyEnc        String?
  polyApiSecretEnc     String?
  polyApiPassphraseEnc String?
  polyFunderAddress    String?
  polySignatureType    Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  copyWallets   CopyWallet[]
  liveTrades    LiveTrade[]
  copyTradeLogs CopyTradeLog[]
  copySettings  UserCopySettings?
  demoBalance   DemoBalance?

  @@index([email])
  @@map("users")
}

model UserCopySettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  minCopyPrice Float    @default(0.004)
  maxCopyPrice Float    @default(0.95)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_copy_settings")
}

model DemoBalance {
  id        String   @id @default("demo")
  userId    String?  @unique
  balance   Float    @default(10000)
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("demo_balance")
}

model DemoTrade {
  id                  String   @id @default(uuid())
  userId              String?
  eventId             String
  eventTitle          String
  marketId            String
  marketQuestion      String
  outcome             String   // YES or NO
  amount              Float
  entryPrice          Float
  exitPrice           Float?
  currentPrice        Float?
  pnl                 Float?
  roi                 Float?
  status              String   // OPEN, CLOSED_WIN, CLOSED_LOSS, CLOSED_MANUAL
  tags                String   @default("[]") // JSON array of tag labels
  sourceWalletAddress String?  // copy-trade: which wallet this position follows
  openedAt            DateTime @default(now())
  closedAt            DateTime?
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([openedAt])
  @@index([sourceWalletAddress])
  @@map("demo_trades")
}

// Local cache for trader profiles (positions + trades stats)
// Written when a wallet profile is opened; used by leaderboard to avoid repeated API calls
model TraderCache {
  address        String   @id                  // lowercase proxy wallet address
  userName       String?
  positionsCount Int      @default(0)
  tradesCount    Int      @default(0)
  avgTradeSize   Float    @default(0)
  positions      String   @default("[]")       // JSON: WalletPosition[]
  recentTrades   String   @default("[]")       // JSON: WalletTrade[]
  fetchedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([updatedAt])
  @@map("trader_cache")
}

// Wallets the user is watching / tracking
model WatchedWallet {
  id            String   @id @default(uuid())
  address       String   @unique
  label         String?  // custom user label
  userName      String?  // from Polymarket
  pnl           Float?   // last known PnL
  vol           Float?   // last known volume
  rank          String?  // leaderboard rank
  notes         String?
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([address])
  @@map("watched_wallets")
}

// Bookmarked convergence markets (where multiple smart wallets agree)
model WatchedConvergence {
  id          String   @id @default(uuid())
  marketId    String   @unique
  title       String
  eventSlug   String?
  notes       String?
  // Snapshot at bookmark time
  consensus   String?  // YES | NO | SPLIT
  walletCount Int?
  avgEntryPrice Float?
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([marketId])
  @@index([addedAt])
  @@map("watched_convergence")
}

// History of convergence signals for win-rate tracking
model ConvergenceHistory {
  id            String   @id @default(uuid())
  marketId      String
  title         String
  eventSlug     String?
  consensus     String   // YES | NO | SPLIT at time of detection
  consensusPct  Int      // 50-100
  walletCount   Int      // how many wallets converged
  wallets       String   // JSON: [{address, userName, outcome, value, entryPrice}]
  totalValue    Float    // combined position value
  avgEntryPrice Float    // weighted avg
  detectedAt    DateTime @default(now())
  
  // Resolution (filled later when market closes)
  resolved      Boolean  @default(false)
  resolvedAt    DateTime?
  winningOutcome String? // YES | NO | null if SPLIT/unresolved
  won           Boolean? // true if consensus matched winning outcome
  actualYesPrice Float?   // 0-1 at resolution
  
  @@index([marketId])
  @@index([detectedAt])
  @@index([resolved])
  @@index([won])
  @@map("convergence_history")
}

// Large trade alert (whale activity > $10K)
model WhaleAlert {
  id             String   @id @default(uuid())
  // Trade identity
  tradeId        String?  @unique  // external trade ID from Data API
  walletAddress  String
  marketId       String
  eventId        String?
  eventTitle     String
  marketQuestion String
  // Trade details
  side           String   // BUY_YES | BUY_NO | SELL_YES | SELL_NO
  outcome        String   // YES | NO
  tradeType      String   // BUY | SELL
  amount         Float    // USD value of trade
  shares         Float    // number of shares
  price          Float    // price per share at trade time
  // Classification
  pattern        String   @default("LARGE_BET") // LARGE_BET | ACCUMULATION | EXIT | REVERSAL | COPY_TRADE
  significance   String   @default("HIGH")      // HIGH | CRITICAL
  // Wallet context
  walletName     String?  // display name from leaderboard or API
  walletPnl      Float?   // wallet's historical PnL from leaderboard
  walletProfit   Float?
  isTopTrader    Boolean  @default(false)        // in top-100 leaderboard
  // Metadata
  tradedAt       DateTime
  detectedAt     DateTime @default(now())

  @@index([walletAddress])
  @@index([marketId])
  @@index([pattern])
  @@index([tradedAt])
  @@index([detectedAt])
  @@map("whale_alerts")
}

// Tracks every generated signal + its eventual outcome for accuracy measurement
model SignalRecord {
  id             String   @id @default(uuid())
  // Signal identity
  marketId       String
  eventId        String
  eventTitle     String
  marketQuestion String
  side           String   // YES | NO
  horizon        String   // fast | medium | long
  category       String
  anomalyTypes   String   @default("[]") // JSON string[]
  reasons        String   @default("[]") // JSON string[]
  // Confidence & price at signal time
  confidence     Int
  confidenceLevel String  // strong | good | speculative
  entryPrice     Float
  potentialRoi   Float
  // Outcome (filled in by cron after market resolves)
  outcome        String   @default("PENDING") // PENDING | WIN | LOSS | VOID
  resolvedAt     DateTime?
  exitPrice      Float?   // price when market resolved
  actualRoi      Float?   // realized ROI if held to resolution
  // CLV (closing line value)
  closingPrice   Float?   // price of our side shortly before resolution
  clvCents       Float?   // (closingPrice - entryPrice) * 100; positive = edge
  // Metadata
  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  snapshots      SignalPriceSnapshot[]

  @@index([outcome])
  @@index([horizon])
  @@index([category])
  @@index([generatedAt])
  @@index([marketId])
  @@map("signal_records")
}

model SignalPriceSnapshot {
  id             String   @id @default(uuid())
  signalRecordId String
  ourSidePrice   Float
  snapshotAt     DateTime @default(now())

  signal         SignalRecord @relation(fields: [signalRecordId], references: [id], onDelete: Cascade)

  @@index([signalRecordId, snapshotAt])
  @@map("signal_price_snapshots")
}

// Global settings for copy-trading (singleton row with id='global')
model CopyTradingSettings {
  id                String  @id @default("global")
  minCopyPrice      Float   @default(0.004)  // skip BUYs cheaper than this (junk outcomes)
  maxCopyPrice      Float   @default(0.95)   // skip BUYs more expensive than this (near-resolved)
  updatedAt         DateTime @updatedAt

  @@map("copy_trading_settings")
}

// One row per wallet we copy — each is a separate "portfolio" (positions grouped by sourceWallet)
model CopyWallet {
  id             String    @id @default(uuid())
  userId         String?
  walletAddress  String
  label          String?   // e.g. "planktonXD"
  amountPerTrade Float     @default(1.0)
  /// Minimum shares per order (Polymarket floor is 5; raise to scale up position size)
  minOrderShares Int       @default(5)
  /// Proportional multiplier: ourUsd = traderUsd * copyScale; amountPerTrade is the ceiling
  copyScale      Float     @default(1.0)
  takeProfitEnabled Boolean @default(false)
  takeProfitRoiPercent Float @default(150.0)
  takeProfitClosePercent Float @default(40.0)
  takeProfitFallbackPrice Float @default(0.80) // if ROI target >= $1, use this price instead
  // Auto-exit stale positions: if held > N days and price dropped > X% from entry
  staleExitEnabled      Boolean @default(true)
  staleExitDays         Int     @default(7)    // exit after this many days if price is bad
  staleExitLossPct      Float   @default(70.0) // exit if price fell more than this % from entry
  // Exit before market closes: exit N hours before endDate if price < entry (avoid holding trash)
  preCloseExitHours     Int     @default(3)    // exit this many hours before market endDate
  enabled        Boolean   @default(true)
  mode           String    @default("demo") // "demo" | "live"
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, walletAddress])
  @@index([userId])
  @@map("copy_wallets")
}

// Tracks real orders placed through CLOB API
model LiveTrade {
  id                  String    @id @default(uuid())
  userId              String?
  sourceWalletAddress String
  conditionId         String
  tokenId             String
  marketTitle         String
  outcome             String
  side                String    // BUY | SELL
  price               Float
  size                Int       // shares
  usdcAmount          Float
  orderId             String?   // from CLOB response
  status              String    @default("PENDING") // PENDING | LIVE | FILLED | FAILED | CANCELLED | CLOSED
  parentTradeId       String?
  isTakeProfit        Boolean   @default(false)
  marketEndDate       DateTime? // when the market closes (from Gamma API), used for pre-close exit
  errorMessage        String?
  copyTradeLogId      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sourceWalletAddress])
  @@index([status])
  @@index([parentTradeId])
  @@index([createdAt])
  @@map("live_trades")
}

model CopyTradeLog {
  id            String   @id @default(uuid())
  userId        String?
  walletAddress String
  action        String   // BUY | SELL
  marketId      String
  marketTitle   String
  outcome       String
  sourcePrice   Float
  copyPrice     Float
  amount        Float
  demoTradeId   String?
  status        String   @default("COPIED") // COPIED | SKIPPED | FAILED
  skipReason    String?
  copiedAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([walletAddress])
  @@index([copiedAt])
  @@index([status])
  @@index([action])
  @@map("copy_trade_logs")
}

// ─── gol.gg scraped stats ────────────────────────────────────────────────────

// Top-league tournaments parsed from /tournament/tournament-matchlist/NAME/
model GolTournament {
  id          String   @id @default(uuid())
  name        String   @unique   // e.g. "2026 First Stand"
  region      String?
  season      String?            // e.g. "S16"
  nbGames     Int?
  firstGame   String?
  lastGame    String?
  scrapedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     GolMatch[]

  @@index([season])
  @@map("gol_tournaments")
}

// Individual game results from tournament-matchlist page
model GolMatch {
  id             String   @id @default(uuid())
  gameId         Int      @unique         // numeric id from gol.gg URL
  tournamentId   String?
  tournamentName String?
  title          String?                  // "G2 Esports vs BLG"
  team1          String?
  team2          String?
  winner         String?
  score          String?                  // "1 - 3"
  stage          String?                  // "FINALS", "GROUPS.DAY1"
  patch          String?
  gameDate       String?
  scrapedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament     GolTournament? @relation(fields: [tournamentId], references: [id])

  @@index([tournamentId])
  @@index([gameDate])
  @@map("gol_matches")
}

// Champion stats from /champion/list/season-S16/split-ALL/tournament-ALL/
model GolChampionStat {
  id           String   @id @default(uuid())
  season       String                     // "S16"
  split        String   @default("ALL")
  tournament   String   @default("ALL")
  champion     String
  picks        Int?
  bans         Int?
  prioScore    String?
  wins         Int?
  losses       Int?
  winrate      String?
  kda          String?
  avgBt        String?  // avg blue side pick
  avgRp        String?  // avg red side pick
  bpPct        String?
  avgGt        String?  // avg game time
  csm          Float?
  dpm          Float?
  gpm          Float?
  csd15        Float?
  gd15         Float?
  xpd15        Float?
  scrapedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([season, split, tournament, champion])
  @@index([season, champion])
  @@map("gol_champion_stats")
}

// Player stats from /players/list/season-S16/split-Winter/tournament-ALL/
model GolPlayerStat {
  id           String   @id @default(uuid())
  season       String
  split        String
  tournament   String   @default("ALL")
  playerId     Int?                       // numeric id from href
  playerName   String
  country      String?
  games        Int?
  winRate      String?
  kda          String?
  avgKills     Float?
  avgDeaths    Float?
  avgAssists   Float?
  csm          Float?
  gpm          Float?
  kpPct        String?
  dmgPct       String?
  goldPct      String?
  vsPct        String?
  dpm          Float?
  vspm         Float?
  avgWpm       Float?
  avgWcpm      Float?
  avgVwpm      Float?
  gd15         Float?
  csd15        Float?
  xpd15        Float?
  fbPct        String?
  fbVictim     String?
  pentaKills   Int?
  scrapedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([season, split, tournament, playerName])
  @@index([season, split])
  @@index([playerName])
  @@map("gol_player_stats")
}

// Per-player champion pool from /players/player-stats/{id}/season-…/split-…/tournament-…/ (gol.gg)
model GolPlayerChampionStat {
  id          String   @id @default(uuid())
  season      String
  split       String
  tournament  String   @default("ALL")
  playerId    Int
  playerName  String?
  championId  Int
  champion    String
  games       Int
  winRate     String?
  kda         String?
  scrapedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([season, split, tournament, playerId, championId])
  @@index([playerId, season, split])
  @@map("gol_player_champion_stats")
}

// Snapshot of a Games of Legends (gol.gg) match page — parsed charts + timeline for analysis / UI
model GolGgGameSnapshot {
  id        String   @id @default(uuid())
  gameId    Int
  pageSlug  String   @default("page-game")
  sourceUrl String
  title     String?
  /// Teams, patch, game duration, winner line (from page headings / meta)
  meta      String   @default("{}")
  /// Chart.js payloads: goldOverTime, goldByRole, damageByRole, vision, jungleShare (counterData)
  charts    String   @default("{}")
  /// Parsed timeline: side, gameTime, label, iconFile
  timeline  String   @default("[]")
  /// Tower plates / voidgrubs row text as structured { raw, teams?, lines? }
  plates    String?
  /// Player stat rows: champion, player, kda, cs, items… (best-effort)
  players   String?
  fetchedAt DateTime @default(now())

  @@unique([gameId, pageSlug])
  @@index([fetchedAt])
  @@map("gol_gg_game_snapshots")
}

// ─── Oracle's Elixir pro-match data ──────────────────────────────────────────

// One row per game (12 source rows collapse into 1 game + 10 player rows)
model OEGame {
  id            String   @id @default(uuid())
  gameId        String   @unique          // e.g. "LOLTMNT05_171038"
  league        String
  year          Int
  split         String
  playoffs      Boolean  @default(false)
  date          DateTime
  patch         String
  gamelength    Int                        // seconds
  blueTeam      String
  redTeam       String
  blueTeamId    String?
  redTeamId     String?
  blueResult    Int                        // 1 = win, 0 = loss
  // Draft: ordered picks & bans
  bluePick1     String?
  bluePick2     String?
  bluePick3     String?
  bluePick4     String?
  bluePick5     String?
  redPick1      String?
  redPick2      String?
  redPick3      String?
  redPick4      String?
  redPick5      String?
  blueBan1      String?
  blueBan2      String?
  blueBan3      String?
  blueBan4      String?
  blueBan5      String?
  redBan1       String?
  redBan2       String?
  redBan3       String?
  redBan4       String?
  redBan5       String?
  // Blue-side first pick
  blueFirstPick Boolean  @default(false)
  createdAt     DateTime @default(now())

  players       OEPlayerGame[]

  @@index([patch])
  @@index([league])
  @@index([date])
  @@index([blueTeam, redTeam])
  @@map("oe_games")
}

// One row per player-game (10 per game: 5 blue + 5 red)
model OEPlayerGame {
  id            String   @id @default(uuid())
  gameId        String
  playername    String
  playerid      String?
  teamname      String
  teamid        String?
  side          String                     // Blue | Red
  position      String                     // top | jng | mid | bot | sup
  champion      String
  result        Int                        // 1 = win
  kills         Int      @default(0)
  deaths        Int      @default(0)
  assists       Int      @default(0)
  dpm           Float?
  cspm          Float?
  gpm           Float?
  vspm          Float?
  golddiffat15  Float?
  xpdiffat15    Float?
  csdiffat15    Float?
  damageshare   Float?
  earnedgoldshare Float?

  game          OEGame   @relation(fields: [gameId], references: [gameId], onDelete: Cascade)

  @@index([gameId])
  @@index([champion])
  @@index([playername])
  @@index([position])
  @@index([teamname])
  @@map("oe_player_games")
}

model StrategySignal {
  id              String   @id @default(uuid())
  strategy        String
  marketId        String
  signal          String   // BUY_YES, BUY_NO, SELL
  confidence      Int      // 0-100
  potentialRoi    Float?
  reasoning       String
  data            String   @default("{}") // JSON как строка для SQLite
  createdAt       DateTime @default(now())

  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([strategy])
  @@index([marketId])
  @@index([createdAt])
  @@map("strategy_signals")
}

// Standalone 5m BTC direction predictions (synced to candle grid); survives restarts
model BtcFiveMinPrediction {
  id               Int      @id @default(autoincrement())
  candleOpenTime   BigInt   @unique // ms UTC, aligned to 5m Binance candles
  candleCloseTime  BigInt
  generatedAt      DateTime
  /// Binance BTCUSDT official OPEN of this 5m candle (window start)
  spot             Float
  direction        String // UP | DOWN
  confidence       Int
  probUp           Float
  indicatorsJson   String   @default("{}")
  resolved         Boolean  @default(false)
  /// Binance BTCUSDT official CLOSE of this 5m candle when resolved
  spotAtExpiry     Float?
  actualDirection  String?
  correct          Boolean?
  changePct        Float?
  /// CoinGecko BTC/USD snapshot near signal time (optional, for comparison to Polymarket-style USD)
  refUsdOpen       Float?
  refUsdClose      Float?

  @@index([candleOpenTime])
  @@index([resolved])
  @@map("btc_five_min_predictions")
}

// BTC strategy auto-trader orders (dry-run and live); resolution + PnL persisted
model BtcAutoTrade {
  id             String    @id @default(uuid())
  timestamp      DateTime
  marketId       String
  question       String
  signal         String // BUY_YES | BUY_NO
  tokenId        String
  price          Float
  size           Float
  edge           Float
  edgePct        Float
  fairValue      Float
  orderId        String?
  status         String // placed | failed | dry_run
  error          String?
  expiryTime     BigInt?
  resolved       Boolean   @default(false)
  outcome        String? // win | loss
  pnl            Float?
  resolvedAt     DateTime?
  resolvedPrice  Float?
  spotAtEntry    Float?
  spotAtExpiry   Float?
  coin           String    @default("bitcoin")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([marketId])
  @@index([resolved])
  @@index([timestamp])
  @@index([coin])
  @@map("btc_auto_trades")
}
