# Скопируй в .env: cp .env.example .env

NODE_ENV=production
PORT=3002

# SQLite (путь относительно папки prisma)
DATABASE_URL="file:./dev.db"

# Origin фронта для CORS / Socket.io (с внешнего IP — подставь http://ТВОЙ_IP:3006 или домен)
FRONTEND_URL=http://127.0.0.1:3006

# --- Live Polymarket CLOB (опционально) ---
# POLY_PRIVATE_KEY=
# POLY_FUNDER_ADDRESS=
# POLY_SIGNATURE_TYPE=2
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=

# --- Telegram (опционально) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Auth & Security ---
# JWT_SECRET=your-jwt-secret-here
# JWT_REFRESH_SECRET=your-refresh-secret-here
# ENCRYPTION_KEY=  # 64-char hex (32 bytes) for AES-256-GCM encryption of Poly keys in DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Admin auto-create (first run) ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-admin-password
# Одноразово сменить пароль существующего админа: поставь =1, перезапусти бэкенд, потом удали строку
# ADMIN_FORCE_PASSWORD_RESET=1

# Восстановление без SSH: POST /api/auth/hostkey-reset-admin (см. README / документацию)

# Если в БД ещё нет ни одного admin — при старте создаётся admin@polysolve.local с паролем PolysolveBootstrap1!
# (логин в форме можно "admin"). Отключить: DISABLE_DEFAULT_ADMIN_BOOTSTRAP=1
# Переопределить: BOOTSTRAP_ADMIN_EMAIL=... BOOTSTRAP_ADMIN_PASSWORD=...
# DISABLE_DEFAULT_ADMIN_BOOTSTRAP=1

# --- LoL / Riot (опционально, см. docs/lol-esports-data-mirofish.md) ---
# RIOT_API_KEY=
# RIOT_REGION=europe   # americas | europe | sea | asia — для scripts/lol-riot-match-json.ts
# PANDASCORE_API_KEY=

# Oracle's Elixir 2026 — скачивание публичного CSV с Drive + импорт в БД (cron 4×/сутки)
# ORACLE_ELIXIR_SYNC_ENABLED=1
# Id файла зашит в коде (DEFAULT_ORACLE_ELIXIR_2026_FILE_ID). Если Oracle перезальёт новый файл — укажи id из ссылки:
# ORACLE_ELIXIR_2026_DRIVE_FILE_ID=
# Опционально, если uc-download ломается: GOOGLE_DRIVE_API_KEY= (Drive API + alt=media)

# --- Прочее ---
# PERPLEXITY_API_KEY=
# BLOCKED_COUNTRIES=  # пусто = дефолтный список Polymarket в коде
