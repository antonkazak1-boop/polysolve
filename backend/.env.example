# Скопируй в .env: cp .env.example .env

NODE_ENV=production
PORT=3002

# SQLite (путь относительно папки prisma)
DATABASE_URL="file:./dev.db"

# Origin фронта для CORS / Socket.io (с внешнего IP — подставь http://ТВОЙ_IP:3006 или домен)
FRONTEND_URL=http://127.0.0.1:3006

# --- Live Polymarket CLOB (опционально) ---
